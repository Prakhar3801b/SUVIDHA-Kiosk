# ─── Supabase / PostgreSQL ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:<YOUR_SUPABASE_PASSWORD>@<YOUR_SUPABASE_HOST>:5432/postgres

# ─── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Security ────────────────────────────────────────────────────
ENCRYPTION_KEY=change_this_to_a_32_char_secret_key!!
ADMIN_API_KEY=change_this_admin_key_for_production

# ─── Government Mock Server ──────────────────────────────────────
GOVT_SERVER_URL=https://your-govt-mock.railway.app

# ─── AI Server (ngrok URL) ───────────────────────────────────────
AI_SERVER_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app

# ─── Batch Sync Threshold ────────────────────────────────────────
SYNC_BATCH_SIZE=10
